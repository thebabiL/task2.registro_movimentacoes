pipeline {
    agent any

    environment {
        PROJECT_DIR = 'registro_movimentacoes'
        IMAGE_NAME = "registro_movimentacoes:${env.BUILD_NUMBER}"
        VM_HOST = '177.44.248.51'
        VM_USER = 'univates'
        VM_BASE_DIR = '/opt/registro-movimentacoes'
        JAVA_OPTS = '-Xms128m -Xmx256m'
        SSH_KEY_FILE = '/var/jenkins_home/.ssh/jenkins_univates'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {
        stage('Registro de mudanca') {
            steps {
                echo 'Mostra o ultimo commit e o estado do repositorio para evidenciar o registro de mudanca.'
                sh 'git log -1 --pretty=format:"Commit: %h%nAutor: %an%nData: %ad%nMensagem: %s"'
                sh 'git status --short'
            }
        }

        stage('Preparar Maven') {
            steps {
                echo 'Garante permissao de execucao para Maven Wrapper e scripts shell.'
                dir(env.PROJECT_DIR) {
                    sh 'chmod +x mvnw scripts/*.sh deploy/*.sh'
                    sh './mvnw -version'
                }
            }
        }

        stage('Testes automatizados') {
            steps {
                echo 'Executa testes automatizados, gera relatorios Surefire/JUnit e cobertura Jacoco.'
                dir(env.PROJECT_DIR) {
                    sh './mvnw -B clean test'
                    sh './scripts/validate-test-count.sh 20'
                }
            }
            post {
                always {
                    dir(env.PROJECT_DIR) {
                        junit 'target/surefire-reports/*.xml'
                        archiveArtifacts artifacts: 'target/site/jacoco/**,target/surefire-reports/**', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Qualidade de codigo') {
            steps {
                echo 'Executa Checkstyle para analise simples de qualidade de codigo.'
                dir(env.PROJECT_DIR) {
                    sh './mvnw -B checkstyle:checkstyle'
                }
            }
            post {
                always {
                    dir(env.PROJECT_DIR) {
                        archiveArtifacts artifacts: 'target/site/checkstyle.html,target/checkstyle-result.xml', allowEmptyArchive: true
                        recordIssues enabledForFailure: true, tools: [checkStyle(pattern: 'target/checkstyle-result.xml')]
                    }
                }
            }
        }

        stage('Build Maven') {
            steps {
                echo 'Gera o arquivo JAR da aplicacao Spring Boot.'
                dir(env.PROJECT_DIR) {
                    sh './mvnw -B -DskipTests package'
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Build Docker') {
            steps {
                echo 'Cria a imagem Docker e salva um arquivo .tar para enviar para a VM via SSH.'
                dir(env.PROJECT_DIR) {
                    sh 'docker build -t ${IMAGE_NAME} .'
                    sh 'mkdir -p target && docker save ${IMAGE_NAME} -o target/app-image.tar'
                    archiveArtifacts artifacts: 'target/app-image.tar', fingerprint: true
                }
            }
        }

        stage('Deploy Integracao') {
            steps {
                echo 'Sobe o ambiente de integracao no proprio servidor Jenkins, porta externa 8081.'
                dir(env.PROJECT_DIR) {
                    sh 'docker compose -f docker-compose.integration.yml down --remove-orphans || true'
                    sh 'docker ps --format "table {{.Names}}\\t{{.Image}}\\t{{.Ports}}" | grep ":8081->" || true'
                    sh 'IMAGE_NAME=${IMAGE_NAME} JAVA_OPTS="${JAVA_OPTS}" docker compose -f docker-compose.integration.yml up -d'
                    sh 'docker compose -f docker-compose.integration.yml ps'
                }
            }
        }

        stage('Deploy Homologacao') {
            steps {
                input message: 'Aprovar deploy em homologacao?', ok: 'Deploy homologacao'
                echo 'Envia a imagem Docker para a VM e atualiza homologacao em http://177.44.248.51:8082.'
                dir(env.PROJECT_DIR) {
                    sh './deploy/deploy.sh homolog ${IMAGE_NAME}'
                }
            }
        }

        stage('Deploy Producao') {
            steps {
                input message: 'Aprovar deploy em producao?', ok: 'Deploy producao'
                echo 'Envia a imagem Docker para a VM e atualiza producao em http://177.44.248.51:8080.'
                dir(env.PROJECT_DIR) {
                    sh './deploy/deploy.sh production ${IMAGE_NAME}'
                }
            }
        }
    }

    post {
        always {
            dir(env.PROJECT_DIR) {
                sh 'docker compose -f docker-compose.integration.yml ps || true'
            }
        }
        success {
            echo 'Pipeline concluido com sucesso.'
        }
        failure {
            echo 'Pipeline falhou. Verifique testes, Checkstyle, Docker ou SSH.'
        }
    }
}
